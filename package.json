{
  "name": "carberra-website",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "sh scripts/dev.sh",
    "build": "vue-tsc --build && vite build && tsc -p tsconfig.server.json",
    "start": "node --env-file=.env server-dist/index.js",
    "preview": "vite preview",
    "format": "prettier --write src/ server/",
    "format:check": "prettier --check src/ server/"
  },
  "dependencies": {
    "express": "^5.2.1",
    "simple-icons": "^16.9.0",
    "vue": "^3.5",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@tsconfig/node22": "^22.0",
    "@types/express": "^5.0.6",
    "@types/node": "^22",
    "@vitejs/plugin-vue": "^5.2",
    "prettier": "^3.5",
    "typescript": "~5.7",
    "vite": "^6.1",
    "vue-tsc": "^2.2"
  }
}
